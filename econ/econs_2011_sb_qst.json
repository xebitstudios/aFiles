			"q0": "A. Px = MUx",
			"q1": "B. Px &ge; MUx",
			"q2": "C. Px > MUx",
			"q3": "D. Px < MUx",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
