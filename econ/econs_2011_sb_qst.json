"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	Human wants are",
		"opts": {
			"q0": "A. limited",
			"q1": "B. scarce",
			"q2": "C. unlimited",
			"q3": "D. in grades",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	The difference between the money cost and the real cost of any item is that",
		"opts": {
			"q0": "A. real cost is the alternative forgone while the money cost is the actual amount paid for buying the item",
			"q1": "B. the real cost is the opportunity cost, while the money cost is the marginal cost",
			"q2": "C. money cost is the opportunity cost, while the real cost is the actual cost in monetary terms",
			"q3": "D. money cost is always greater than real cost",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	The Production Possibility Curve (PPC) indicates that as more of one good is produced",
		"opts": {
			"q0": "A. less of the other good is produced",
			"q1": "B. the same quantity of the other good is produced",
			"q2": "C. more of the other good is produced",
			"q3": "D. none of the other good is produced",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	An arrangement of data in rows and columns is referred to as a",
		"opts": {
			"q0": "A. graph",
			"q1": "B. bar chart",
			"q2": "C. pie chart",
			"q3": "D. table",
			"q4": "E. "
		},
		"ans": "D", 
		"sel": ""
	},
	"Q5": {
		"qs": "5.	A normal demand curve slopes",
		"opts": {
			"q0": "A. downwards from left to right",
			"q1": "B. upwards from right to left",
			"q2": "C. downwards from right to left",
			"q3": "D. upwards from left to right",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q6": {
		"qs": "6.	The co-efficient of income elasticity of demand for inferior goods is",
		"opts": {
			"q0": "A. positive",
			"q1": "B. equal to one",
			"q2": "C. less than one",
			"q3": "D. negative",
			"q4": "E. "
		},
		"ans": "D", 
		"sel": ""
	},
	"Q7": {
		"qs": "7.	If a 20% rise in the price of Whisky leads to a 30% increase in quantity demanded of Schnapps, the cross elasticity of demand is",
		"opts": {
			"q0": "A. 3.0",
			"q1": "B. 2.5",
			"q2": "C. 2.3",
			"q3": "D. 1.5",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
