		"qs": "46.	An important feature of economic development is",
		"opts": {
			"q0": "A. population explosion",
			"q1": "B. reduction in exports",
			"q2": "C. high literacy level",
			"q3": "D. low exports",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q47": {
		"qs": "47.	Trade among nations is desirable because it",
		"opts": {
			"q0": "A. enables people in a country to know those in other countries",
			"q1": "B. makes it possible for people in a country to enjoy the goods and services produced in other countries",
			"q2": "C. enables residents in a country to understand the language of residents of other countries",
			"q3": "D. makes it possible for a country to have the currencies of other countries",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q48": {
		"qs": "48.	Invisible trade refers to trade in",
		"opts": {
			"q0": "A. services",
			"q1": "B. goods and services",
			"q2": "C. tangible goods",
			"q3": "D. crude oil",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q49": {
		"qs": "49.	Payment surplus implies that the value of the country’s",
		"opts": {
			"q0": "A. exports exceeds its imports",
			"q1": "B. imports exceeds its exports",
			"q2": "C. exports is equal to its imports",
			"q3": "D. terms of trade is constant",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q50": {
		"qs": "50.	The Economic Commission for Africa is an agency of the",
		"opts": {
			"q0": "A. Organization of African Unity",
