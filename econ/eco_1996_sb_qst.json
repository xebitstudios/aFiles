		"ans": "A", 
		"sel": ""
	},
	"Q6": {
		"qs": "6.	If the price of a commodity rises from N2.00 to N4.00 and its supply increases from 100 to 125, then the co-efficient of elasticity of supply is",
		"opts": {
			"q0": "A. 0.025",
			"q1": "B. 0.24",
			"q2": "C. 0.22",
			"q3": "D. 0.25",
			"q4": "E. 0.23"
		},
		"ans": "D", 
		"sel": ""
	},
	"Q7": {
		"qs": "7.	If as a result of a fall in the price of commodity X, the quantity demanded of commodity Y falls, then commodities X and Y are",
		"opts": {
			"q0": "A. complementary",
			"q1": "B. in joint demand",
			"q2": "C. luxuries",
			"q3": "D. in composite demand",
			"q4": "E. substitutes"
		},
		"ans": "E",
		"sel": ""
	},
	"Q8": {
		"qs": "8.	MUX = PX (where X and Y = good X and good Y; MU = Marginal Utility; P = Price). MUY = PY. The above represents the",
		"opts": {
			"q0": "A. marginal utility equation",
			"q1": "B. equation for consumer dis-equilibrium",
			"q2": "C. utility maximization equation",
			"q3": "D. equation for total utility",
			"q4": "E. equation for price elasticity"
		},
		"ans": "C",
		"sel": ""
	},
	"Q9": {
		"qs": "9.	Subsistence agriculture means",
		"opts": {
			"q0": "A. cultivation for external use",
			"q1": "B. cultivation for local industries",
			"q2": "C. farming for the urban dwellers",
			"q3": "D. cultivation for household consumption",
			"q4": "E. cultivation for foreign currency"
		},
		"ans": "D",
		"sel": ""
	},
	"Q10": {
		"qs": "10.	Farm produce are graded, packed and distributed by",
		"opts": {
			"q0": "A. purchasing co-operatives",
			"q1": "B. agricultural co-operative bank",
			"q2": "C. consumers co-operative society",
			"q3": "D. marketing co-operatives",
			"q4": "E. wholesale co-operatives"
		},
		"ans": "D",
		"sel": ""
	},
	"Q11": {
		"qs": "11.	Localization of industries is",
		"opts": {
			"q0": "A. the industrialization of a country",
			"q1": "B. the concentration of the firms of an industry in a particular area",
			"q2": "C. the location of a firm at a particular locality",
