		"qs": "20.	All the following are the economic reasons for establishing public enterprises except the provision of",
		"opts": {
			"q0": "A. an avenue for expressing national prestige",
			"q1": "B. services at a cheaper cost",
			"q2": "C. socially necessary facilities",
			"q3": "D. services which are natural monopolies",
			"q4": "E. employment opportunities"
		},
		"ans": "A",
		"sel": ""
	},
