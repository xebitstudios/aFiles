		"qs": "21.	The unemployment associated with decrease in demand is referred to as",
		"opts": {
			"q0": "A. disguised",
			"q1": "B. imposed",
			"q2": "C. cyclical",
			"q3": "D. voluntary",
			"q4": "E. functional"
		},
		"ans": "C",
		"sel": ""
	},
	"Q22": {
		"qs": "22.	Monopoly can best be described as a market in which",
		"opts": {
			"q0": "A. a single seller sells a product which has no close substitute",
			"q1": "B. few sellers sell a product at different prices",
			"q2": "C. the entry of other firms is restricted by the few firms in the market",
			"q3": "D. two or more sellers sell a product which is differentiated",
			"q4": "E. a single buyer buys a product which has no close substitute"
		},
		"ans": "A",
		"sel": ""
	},
