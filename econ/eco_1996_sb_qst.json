"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	The basic problem that Economics attempts to solve is the",
		"opts": {
			"q0": "A. ranking of goods and services",
			"q1": "B. pricing of goods and services",
			"q2": "C. scarcity of resources",
			"q3": "D. foregoing of alternatives",
			"q4": "E. satisfaction of producers’ needs"
		},
		"ans": "C", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	The ranking of a consumers’ needs in order of importance is termed",
		"opts": {
			"q0": "A. an opportunity cost",
			"q1": "B. economies of scale",
			"q2": "C. a scale of preference",
			"q3": "D. the making of choice",
			"q4": "E. direct production"
		},
		"ans": "C", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	<img src='eco_1996_sectionb_qst3_5.jpg'> Use the diagram below to answer questions 3 to 5. The total number of fruits consumed by a family in a year is 720, and this is represented by the pie chart below. The quantity of banana consumed by the family is",
		"opts": {
			"q0": "A. 60",
			"q1": "B. 120",
			"q2": "C. 200",
			"q3": "D. 240",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	<img src='eco_1996_sectionb_qst3_5.jpg'> Use the diagram below to answer questions 3 to 5. The total number of fruits consumed by a family in a year is 720, and this is represented by the pie chart below. The sum total of the quantity of mango and orange consumed by the family is",
		"opts": {
			"q0": "A. 120",
			"q1": "B. 200",
			"q2": "C. 360",
			"q3": "D. 400",
			"q4": "E. 520"
		},
		"ans": "D", 
		"sel": ""
	},
	"Q5": {
		"qs": "5.	<img src='eco_1996_sectionb_qst3_5.jpg'> Use the diagram below to answer questions 3 to 5. The total number of fruits consumed by a family in a year is 720, and this is represented by the pie chart below. The quantity of carrot consumed by the family is",
		"opts": {
			"q0": "A. 200",
			"q1": "B. 360",
			"q2": "C. 400",
			"q3": "D. 520",
			"q4": "E. 600"
