	"Q12": {
		"qs": "12.	Which of the following correctly illustrates the chain of distribution?",
		"opts": {
			"q0": "A. Manufacturer -> wholesaler -> retailer -> consumer",
			"q1": "B. Consumer -> retailer -> wholesaler -> manufacture",
			"q2": "C. Wholesaler -> manufacturer -> retailer -> consumer",
			"q3": "D. Distributor -> consumer -> wholesaler -> manufacturer",
			"q4": "E. Producer -> manufacturer -> wholesaler -> retailer"
		},
		"ans": "A",
		"sel": ""
	},
	"Q13": {
		"qs": "13.	The natural growth rate of a population is the",
		"opts": {
			"q0": "A. death rate plus net immigration",
			"q1": "B. rate of migration divided by birth rate",
			"q2": "C. birth rate minus death rate",
			"q3": "D. sum of birth rate and net immigration rate",
			"q4": "E. sum of birth rate and death rate"
		},
		"ans": "C",
		"sel": ""
	},
	"Q14": {
		"qs": "14.	Decreasing returns to scale implies that if ali factors of production are doubled, output will be",
		"opts": {
			"q0": "A. more than doubled ",
			"q1": "B. less than doubled",
			"q2": "C. doubled",
			"q3": "D. unchanged",
			"q4": "E. trebled"
		},
		"ans": "B",
		"sel": ""
	},
