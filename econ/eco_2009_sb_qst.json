			"q0": "A. The law of variable proportions",
			"q1": "B. Increasing returns to scale",
			"q2": "C. Decreasing use of inputs",
			"q3": "D. Changing output during the production period",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
