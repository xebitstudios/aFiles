		"opts": {
			"q0": "A. P = AR < MR",
			"q1": "B. P > AR = MR",
			"q2": "C. P = MR < AR",
			"q3": "D. P = AR = MR",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
