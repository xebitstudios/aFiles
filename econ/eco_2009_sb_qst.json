"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	The study of Economics becomes necessary because of the",
		"opts": {
			"q0": "A. large population size of the world",
			"q1": "B. scarcity of resources",
			"q2": "C. opportunity cost of goods and services",
			"q3": "D. need to satisfy every desire of man",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	The concept of opportunity cost is also referred to as",
		"opts": {
			"q0": "A. social cost",
			"q1": "B. real cost",
			"q2": "C. fixed cost",
			"q3": "D. variable cost",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	Choice is necessitated by",
		"opts": {
			"q0": "A. demand and supply",
			"q1": "B. cost of production",
			"q2": "C. production possibility curve",
			"q3": "D. scarcity of resources",
			"q4": "E. "
		},
		"ans": "D", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	A type of unemployment which occurs due to technological progress is called",
		"opts": {
			"q0": "A. frictional unemployment",
			"q1": "B. residual unemployment",
			"q2": "C. structural unemployment",
			"q3": "D. mass unemployment",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q5": {
		"qs": "5.	All the following are features of market economies except",
		"opts": {
			"q0": "A. competition among producers",
			"q1": "B. demand and supply forces guiding production decisions",
			"q2": "C. that profit motive is paramount",
			"q3": "D. public ownership of capital",
			"q4": "E. "
		},
		"ans": "D", 
		"sel": ""
	},
	"Q6": {
		"qs": "6.	The economic system which relies mainly on the price mechanism for the allocation of scarce resources is known as",
		"opts": {
			"q0": "A. capitalist economic system",
			"q1": "B. command economic system",
			"q2": "C. combined economic system",
			"q3": "D. traditional economic system",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q7": {
		"qs": "7.	In a capitalist economy, resources are",
		"opts": {
			"q0": "A. collectively owned",
			"q1": "B. jointly owned",
			"q2": "C. privately owned",
			"q3": "D. communally owned",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q8": {
		"qs": "8.	An economic system where the central planning authority determines what goods to produce and in what quantity is known as a",
		"opts": {
			"q0": "A. market economy",
			"q1": "B. socialist economy",
			"q2": "C. welfare economy",
			"q3": "D. traditional economy",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q9": {
		"qs": "9.	The main objective of setting up a private business organization is to",
		"opts": {
			"q0": "A. protect the interest of the owners",
			"q1": "B. promote exports",
			"q2": "C. provide infrastructure",
			"q3": "D. maximize profits",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q10": {
		"qs": "10.	The demand and supply functions of a commodity are given as follows: Qd = 20 -2p and Qs = 6p-12 where p = price in naira, Qd = Quantity demanded and Qs = Quantity supplied. The equilibrium price is",
		"opts": {
			"q0": "A. 2 Naira",
			"q1": "B. 4 Naira",
			"q2": "C. 6 Naira",
			"q3": "D. 20 Naira",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q11": {
		"qs": "11.	The type of demand that exists between torchlight and battery is",
		"opts": {
			"q0": "A. competitive demand",
			"q1": "B. complementary demand",
			"q2": "C. composite demand",
			"q3": "D. independent demand",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q12": {
		"qs": "12.	When the price of a commodity increases and the quantity demanded also increases, this is a case of",
		"opts": {
			"q0": "A. exceptional demand",
			"q1": "B. derived demand",
			"q2": "C. competitive demand",
			"q3": "D. joint demand",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q13": {
		"qs": "13.	If a fall in price of one commodity leads to an increase in the supply of another commodity, both commodities have",
		"opts": {
			"q0": "A. composite supply",
			"q1": "B. joint supply",
			"q2": "C. competitive supply",
			"q3": "D. short run supply",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q14": {
		"qs": "14.	At a co-efficient of price elasticity of supply of 0.5, supply is",
		"opts": {
			"q0": "A. perfectly inelastic",
			"q1": "B. inelastic",
			"q2": "C. perfectly elastic",
			"q3": "D. elastic",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q15": {
		"qs": "15.	If in the short-run commodity X and commodity Y are supplied jointly, which of the following is correct?",
		"opts": {
			"q0": "A. An increase in demand for X will increase supply of Y",
			"q1": "B. An increase in demand for X will leave the supply of Y unchanged",
			"q2": "C. An increase in demand for Y will raise the price of X",
			"q3": "D. An increase in demand for X will cause less of Y to be produced",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q16": {
		"qs": "16.	If an increase in earnings leads to more of a commodity being demanded, the good is said to have",
		"opts": {
			"q0": "A. positive income elasticity",
			"q1": "B. negative income elasticity",
			"q2": "C. positive cross elasticity",
			"q3": "D. negative cross elasticity",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q17": {
		"qs": "17.	Interaction of supply and demand for labour determines",
		"opts": {
			"q0": "A. production",
			"q1": "B. income",
			"q2": "C. wage",
			"q3": "D. profit",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q18": {
		"qs": "18.	Government fixing of prices below the equilibrium point is aimed at protecting the",
		"opts": {
			"q0": "A. sellers",
			"q1": "B. industries",
			"q2": "C. distributors",
			"q3": "D. consumers",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q19": {
		"qs": "19.	A consumer maximizes his utility in consuming a good ‘x’ when",
		"opts": {
			"q0": "A. Mux = Px",
			"q1": "B. Px > Mux",
			"q2": "C. Price is falling",
			"q3": "D. Mux > Px",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
