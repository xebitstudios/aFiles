		"qs": "20.	The relationship between Marginal Product (MP) and Average Product (AP) is such that they are equal when",
		"opts": {
			"q0": "A. Average Product is maximum",
			"q1": "B. Average Product is minimum",
			"q2": "C. Marginal Product is maximum",
			"q3": "D. Marginal Product is increasing",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
