		"qs": "16.	The gap between demand and supply curves below the equilibrium price indicates",
		"opts": {
			"q0": "A. excess demand",
			"q1": "B. excess supply",
			"q2": "C. equilibrium quantity",
			"q3": "D. equilibrium price",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q17": {
		"qs": "17.	Demand for inferior good is an example of",
		"opts": {
			"q0": "A. expansion of demand",
			"q1": "B. contraction of demand",
			"q2": "C. individual demand",
			"q3": "D. abnormal demand",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q18": {
		"qs": "18.	When a change in price does not affect the quantity demanded of a commodity, the price elasticity of demand is",
		"opts": {
			"q0": "A. fairly inelastic",
			"q1": "B. infinitely elastic",
			"q2": "C. perfectly inelastic",
			"q3": "D. unitary elastic",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
