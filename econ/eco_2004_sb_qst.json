		"qs": "14.	One of the problems associated with the middleman in the distribution of goods is that he",
		"opts": {
			"q0": "A. buys in large quantities",
			"q1": "B. hoards goods",
			"q2": "C. grants credit to the retailer",
			"q3": "D. sells varieties of goods",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q15": {
		"qs": "15.	The distribution of goods is said fo be completed when it reaches the",
		"opts": {
			"q0": "A. wholesalers",
			"q1": "B. consumers",
			"q2": "C. retailers",
			"q3": "D. manufacturers",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
