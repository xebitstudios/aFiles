"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	Which of the following is an economic activity?",
		"opts": {
			"q0": "A. attending a town’s meeting",
			"q1": "B. a visit to the stadium",
			"q2": "C. payment of school fees",
			"q3": "D. arresting a petty thief",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	The reward for land as a factor of production is",
		"opts": {
			"q0": "A. interest",
			"q1": "B. rent",
			"q2": "C. dividend",
			"q3": "D. wages",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	The three broad categories of production are",
		"opts": {
			"q0": "A. direct, secondary and extractive",
			"q1": "B. primary, tertiary and direct",
			"q2": "C. primary, secondary and tertiary",
			"q3": "D. secondary, primary and indirect",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	A carpenter’s consumer goods include I. a kilogram of rice II. 3 pairs of shoes III. 4 pairs of socks IV. 3 screw-drivers.",
		"opts": {
			"q0": "A. I and IV only",
			"q1": "B. I, II, III and IV",
			"q2": "C. I, II and IV only",
			"q3": "D. I, II and III only",
			"q4": "E. "
		},
		"ans": "D", 
		"sel": ""
	},
	"Q5": {
		"qs": "5.	In a capitalist system, the means of production is owned and controlled by",
		"opts": {
			"q0": "A. the government",
			"q1": "B. politicians",
			"q2": "C. private individuals",
			"q3": "D. the workers",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q6": {
		"qs": "6.	Mixed economy refers to a system in which the means of production are controlled by",
		"opts": {
			"q0": "A. private enterprise and the government",
			"q1": "B. private individuals",
			"q2": "C. the government only",
			"q3": "D. the workers and businessmen",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q7": {
		"qs": "7.	An economic good is described as a good which",
		"opts": {
			"q0": "A. yields utility and commands a price",
			"q1": "B. is useful and occupies a space",
			"q2": "C. is in high demand and transferable",
			"q3": "D. has unlimited supply",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q8": {
		"qs": "8.	The concept of opportunity cost is important to the firm because it",
		"opts": {
			"q0": "A. determines the prices of the firm’s products",
			"q1": "B. increases the level of output of the firm",
			"q2": "C. leads to maximum satisfaction of the consumers",
			"q3": "D. guides firms in allocating scarce resources",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q9": {
		"qs": "9.	As a firm expands, it enjoys some advantages called",
		"opts": {
			"q0": "A. variable proportions",
			"q1": "B. diminishing marginal returns",
			"q2": "C. internal economies of scale",
			"q3": "D. decreasing returns to scale",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q10": {
		"qs": "10.	Division of labour is limited by",
		"opts": {
			"q0": "A. the size of the market",
			"q1": "B. the productivity of capital",
			"q2": "C. cost of production",
			"q3": "D. the factors of production",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q11": {
		"qs": "11.	An entrepreneur is likely to make more profits when",
		"opts": {
			"q0": "A. expenditure is more than revenue",
			"q1": "B. competitors charge lower prices",
			"q2": "C. cost per unit output falls",
			"q3": "D. quantity of output reduces",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q12": {
		"qs": "12.	Natural growth rate is",
		"opts": {
			"q0": "A. birth rate less death rate",
			"q1": "B. death rate less migration",
			"q2": "C. death rate plus birth rate",
			"q3": "D. birth rate plus migration",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q13": {
		"qs": "13.	A major effect of ageing population is",
		"opts": {
			"q0": "A. reduced labour force",
			"q1": "B. rise in prices of commodities",
			"q2": "C. reduced infrastructure",
			"q3": "D. neglect of agriculture",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
