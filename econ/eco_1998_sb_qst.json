		"qs": "34.	The stability of the Nigerian economy depends mainly on the export price of",
		"opts": {
			"q0": "A. groundnut",
			"q1": "B. cotton",
			"q2": "C. cocoa",
			"q3": "D. mineral oil",
			"q4": "E. palm kernel"
		},
		"ans": "D",
		"sel": ""
	},
