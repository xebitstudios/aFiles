	"Q38": {
		"qs": "38.	Which of the following constitutes the largest exports of the developing countries to the developed ones?",
		"opts": {
			"q0": "A. Raw materials",
			"q1": "B. Finished consumer goods",
			"q2": "C. Labour services",
			"q3": "D. Arms and ammunition",
			"q4": "E. Automobiles"
		},
		"ans": "A",
		"sel": ""
	},
	"Q39": {
		"qs": "39.	The economic system in which the decisions about what to produce, how to produce and for whom to produce are made by private firms is called",
		"opts": {
			"q0": "A. socialism",
			"q1": "B. welfarism",
			"q2": "C. communism",
			"q3": "D. capitalism",
			"q4": "E. traditionalism"
		},
		"ans": "D",
		"sel": ""
	},
	"Q40": {
		"qs": "40.	A major setback in any mixed economy is",
		"opts": {
			"q0": "A. that is combines both the capitalist and socialist systems",
			"q1": "B. the freedom of choice in the production and consumption of goods and services",
			"q2": "C. that government intervenes to secure full utilization of resources",
			"q3": "D. that economic decisions are determined by market forces",
