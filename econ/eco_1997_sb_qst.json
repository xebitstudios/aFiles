		"ans": "C",
		"sel": ""
	},
	"Q15": {
		"qs": "15.	For two commodities A and Bt MA and MB are the respective marginal utitilies while PA and PB are the respective prices. Marginal utilities of the two commodities are maximized when",
		"opts": {
			"q0": "A. <sup>MA</sup>&frasl;<sub>PA</sub> = <sup>MB</sup>&frasl;<sub>PB</sub>",
			"q1": "B. <sup>MA</sup>&frasl;<sub>PA</sub> > <sup>MB</sup>&frasl;<sub>PB</sub>",
			"q2": "C. <sup>MA</sup>&frasl;<sub>PA</sub> < <sup>MB</sup>&frasl;<sub>PB</sub>",
			"q3": "D. <sup>PA</sup>&frasl;<sub>MA</sub> < <sup>PB</sup>&frasl;<sub>MB</sub>",
			"q4": "E. <sup>PA</sup>&frasl;<sub>MA</sub> > <sup>PB</sup>&frasl;<sub>MB</sub>"
		},
		"ans": "A",
		"sel": ""
