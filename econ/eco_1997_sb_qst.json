"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	Economics is often described as a science because it",
		"opts": {
			"q0": "A. adopts the use of laboratory experiments",
			"q1": "B. involves accurate prediction of human beings",
			"q2": "C. makes use of controlled experiments",
			"q3": "D. uses scientific methods to explain observed phenomena",
			"q4": "E. deals with observations and field work"
		},
		"ans": "D", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	Scarcity in Economics means that",
		"opts": {
			"q0": "A. the economy can scarcely produce anything",
			"q1": "B. human wants are limitless",
			"q2": "C. the economy has very few resources",
			"q3": "D. human wants are limited, relative to resources",
			"q4": "E. resources are limited relative to wants"
		},
		"ans": "E", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	Which of the following has a derived demand?",
		"opts": {
			"q0": "A. labour",
			"q1": "B. butter",
			"q2": "C. television sets",
			"q3": "D. bread",
			"q4": "E. motor cars"
		},
		"ans": "A", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	In Economics, production is complete when",
		"opts": {
			"q0": "A. goods are manufactured in the factories",
			"q1": "B. commodities are sold to the final consumer",
			"q2": "C. goods and services are distributed by the government",
			"q3": "D. producers fix the price of the goods produced",
			"q4": "E. goods and services get to the retailers"
		},
		"ans": "B", 
		"sel": ""
	},
	"Q5": {
		"qs": "5.	Goods are said to be in competitive demand when they",
		"opts": {
			"q0": "A. are substitutes",
			"q1": "B. are complementary to each other",
			"q2": "C. are jointly demanded",
			"q3": "D. have equal coefficients of elasticity",
			"q4": "E. are identical"
		},
		"ans": "A", 
		"sel": ""
	},
	"Q6": {
		"qs": "6.	The formula for calculating price elasticity of demand coefficient is",
		"opts": {
			"q0": "A. <sup>percentage change in price</sup>&frasl;<sub>percentage change in quantity demanded</sub>",
			"q1": "B. <sup>absolute decline in price</sup>&frasl;<sub>absolute increase in quantity demanded</sub>",
			"q2": "C. <sup>percentage change in quantity demanded</sup>&frasl;<sub>percentage change in price</sub>",
			"q3": "D. <sup>absolute decline in quantity demanded</sup>&frasl;<sub>absolute increase in price</sub>",
			"q4": "E. <sup>change in quantity demanded</sup>&frasl;<sub>decrease in price</sub>"
		},
		"ans": "C", 
		"sel": ""
	},
	"Q7": {
		"qs": "7.	When the price of a given product is reduced from N100 to N90, the quantity demanded increases from 50 to 60 units. From this we can conclude that the product’s",
		"opts": {
			"q0": "A. demand is elastic",
			"q1": "B. demand is inelastic",
			"q2": "C. demand is perfectly inelastic",
			"q3": "D. supply is not elastic",
			"q4": "E. demand has declined"
		},
		"ans": "B",
		"sel": ""
	},
	"Q8": {
		"qs": "8.	A shift in the supply curve to the right will result in a",
		"opts": {
			"q0": "A. fall in both the price and supply",
			"q1": "B. fall in price but an increase in supply",
			"q2": "C. rise in both price and supply",
			"q3": "D. rise in price and a fall in supply",
			"q4": "E. no change in price and supply"
		},
		"ans": "B",
		"sel": ""
	},
	"Q9": {
		"qs": "9.	One of the disadvantages of division of labour is that it",
		"opts": {
			"q0": "A. saves time",
			"q1": "B. makes work monotonous",
			"q2": "C. encourages full utilization of capital",
			"q3": "D. makes workers skilled at their work",
			"q4": "E. allows greater use of machinery"
		},
		"ans": "B",
		"sel": ""
	},
	"Q10": {
		"qs": "10.	The value of money is affected by the",
		"opts": {
			"q0": "A. speculative motive",
			"q1": "B. price level",
			"q2": "C. transactionary motive",
			"q3": "D. precautionary motive",
			"q4": "E. employment level"
		},
		"ans": "B",
		"sel": ""
	},
	"Q11": {
		"qs": "11.	Which of following is not a problem in the barter economy?",
		"opts": {
			"q0": "A. multiple exchange rate",
			"q1": "B. indivisibility of goods and services",
			"q2": "C. double coincidence of wants",
			"q3": "D. bulkness of commodities",
			"q4": "E. inflation"
		},
		"ans": "E",
		"sel": ""
	},
	"Q12": {
		"qs": "12.	The optimum population of a country is reached when the",
		"opts": {
			"q0": "A. production of goods and services is less than optimum",
			"q1": "B. output per head is at its highest with a given volume of resources",
			"q2": "C. total production increases with a given volume of resources",
			"q3": "D. national resources increases as population increases",
			"q4": "E. working population rises at a geometrical rate"
		},
		"ans": "B",
		"sel": ""
	},
	"Q13": {
		"qs": "13.	When the death rate for old people and the infant mortality rate are high, with no migration, there will be in the population a higher number of",
		"opts": {
			"q0": "A. younger people in the population",
			"q1": "B. children in the population",
			"q2": "C. old people in the population",
			"q3": "D. women in the population",
			"q4": "E. men in the population"
		},
		"ans": "A",
		"sel": ""
	},
	"Q14": {
		"qs": "14.	In the long-run, potential GNP is variable because I. technological change takes place II. the quantity of labour and capital is not fixed III. unemployment is not constant",
		"opts": {
			"q0": "A. I only",
			"q1": "B. II only",
			"q2": "C. I and II only",
			"q3": "D. I and III only",
			"q4": "E. III only"
