	"Q16": {
		"qs": "16.	If the price of product K declines, the demand curve for the complementary product J wil",
		"opts": {
			"q0": "A. remain unchanged",
			"q1": "B. shift to the right",
			"q2": "C. decrease",
			"q3": "D. shift to the left",
			"q4": "E. slope upwards"
		},
		"ans": "D",
		"sel": ""
