"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	Economics is regarded as a science because it",
		"opts": {
			"q0": "A. studies laws that govern human behaviour",
			"q1": "B. uses scientific method to explain human behaviour",
			"q2": "C. makes use of controlled experiments to explain human behavior",
			"q3": "D. makes use of machines to study human behaviour",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	Which of the following cannot be described as land?",
		"opts": {
			"q0": "A. forest",
			"q1": "B. Diamond",
			"q2": "C. Roads",
			"q3": "D. Crude oil",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	An outward shift of the production possibility curve shows that",
		"opts": {
			"q0": "A. production is shifting to the right",
			"q1": "B. resources are underutilized",
			"q2": "C. economic growth has taken place",
			"q3": "D. factors of production are moving outward",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	The following constitute the criteria for identifying an economic system except",
		"opts": {
			"q0": "A. ownership of resources",
			"q1": "B. scarcity of resources",
			"q2": "C. method of decision making",
			"q3": "D. motivation for production",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
