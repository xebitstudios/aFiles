		"qs": "6.	Which of the following is not an effect of many middlemen in the chain of distribution?",
		"opts": {
			"q0": "A. Shortage of commodities",
			"q1": "B. Low retail prices",
			"q2": "C. Hoarding of goods",
			"q3": "D. High retail prices",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
