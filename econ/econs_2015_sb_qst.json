		"qs": "5.	A disadvantage of the mean as a measure of central tendency is that, it",
		"opts": {
			"q0": "A. is affected by extreme values",
			"q1": "B. can only be used for continuous data",
			"q2": "C. cannot be used to measure the qualities of a population",
			"q3": "D. cannot be determined in grouped data",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
