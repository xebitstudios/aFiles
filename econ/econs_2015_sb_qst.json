		"qs": "7.	If the price of flour rises then bread’s",
		"opts": {
			"q0": "A. demand curve will shift to the left while supply curve will shift to the right.",
			"q1": "B. supply curve will shift to the left",
			"q2": "C. supply curve will shift to the right",
			"q3": "D. demand curve will shift to the right while supply curve remains unchanged",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
