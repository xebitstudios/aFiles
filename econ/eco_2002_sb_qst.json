"qst": {
	"headd": "Answer all the questions",
	"Q1": {
		"qs": "1.	Economics is best described as the study of",
		"opts": {
			"q0": "A. the wealth of nations",
			"q1": "B. how man consumes his products",
			"q2": "C. how man provides for his everyday needs",
			"q3": "D. the distribution of wealth",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q2": {
		"qs": "2.	<img src='eco_2002_sectionb_qst2.jpg'> The pie-chart below represents the total population of a school of 1,200. The shaded area of 60° shows the population of the underaged pupils. What is the population of the matured students?",
		"opts": {
			"q0": "A. 600",
			"q1": "B. 800",
			"q2": "C. 1000",
			"q3": "D. 1200",
			"q4": "E. "
		},
		"ans": "C", 
		"sel": ""
	},
	"Q3": {
		"qs": "3.	The most frequently occurring value in a given, data is the",
		"opts": {
			"q0": "A. mode",
			"q1": "B. median",
			"q2": "C. mean",
			"q3": "D. range",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q4": {
		"qs": "4.	Subsistence production means that goods and services are",
		"opts": {
			"q0": "A. produced for consumption only",
			"q1": "B. sold to others",
			"q2": "C. sold in the country",
			"q3": "D. produced for the market",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q5": {
		"qs": "5.	Warehouse facilities in the distribution and marketing of products are provided by",
		"opts": {
			"q0": "A. manufacturers",
			"q1": "B. wholesalers",
			"q2": "C. retailers",
			"q3": "D. advertisers",
			"q4": "E. "
		},
		"ans": "B", 
		"sel": ""
	},
	"Q6": {
		"qs": "6.	Which of the following is a reward to a factor of production?",
		"opts": {
			"q0": "A. Interest",
			"q1": "B. Donation",
			"q2": "C. Gift",
			"q3": "D. Subsidy",
			"q4": "E. "
		},
		"ans": "A", 
		"sel": ""
	},
	"Q7": {
		"qs": "7.	Land is a factor of production because it",
		"opts": {
			"q0": "A. is a free gift of nature",
			"q1": "B. contains valuable mineral resources",
			"q2": "C. assists in the creation of utility",
			"q3": "D. is owned by individuals and governments",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q8": {
		"qs": "8.	One of the advantages of large scale production is that",
		"opts": {
			"q0": "A. there is a rise in the cost of administration",
			"q1": "B. consumers sacrifice their individual tastes",
			"q2": "C. the firm can use labour-saving machinery",
			"q3": "D. the demand for a firm’s products becomes localized",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q9": {
		"qs": "9.	Which of the following is an advantage of division of labour?",
		"opts": {
			"q0": "A. Production of specialized goods",
			"q1": "B. Employment of experts",
			"q2": "C. Monotony of work",
			"q3": "D. Greater use of machinery",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q10": {
		"qs": "10.	Despite the benefits large firms enjoy, it could be limited by the",
		"opts": {
			"q0": "A. desire to make maximum profits",
			"q1": "B. introduction of efficient transport system",
			"q2": "C. growth of specialization",
			"q3": "D. extent of the market",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q11": {
		"qs": "11.	Localization of industry refers to the",
		"opts": {
			"q0": "A. concentration of the firms of an industry in a particular area",
			"q1": "B. siting of industries in rural areas",
			"q2": "C. even spread of industries",
			"q3": "D. government policy of influencing the location of industries",
			"q4": "E. "
		},
		"ans": "A",
		"sel": ""
	},
	"Q12": {
		"qs": "12.	Economists speak about ‘opportunity cost’ when a consumer",
		"opts": {
			"q0": "A. has the chance to minimize costs",
			"q1": "B. has to forgo one thing in order to have another",
			"q2": "C. can equate his fixed costs with his variable costs",
			"q3": "D. is able to save part of his income",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q13": {
		"qs": "13.	The costs which a firm will incur whether it is in production or not, is referred to as",
		"opts": {
			"q0": "A. average cost",
			"q1": "B. variable cost",
			"q2": "C. opportunity cost",
			"q3": "D. fixed cost",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q14": {
		"qs": "14.	<img src='eco_2002_sectionb_qst14.jpg'> Which of the curves in the diagram below represents the firm’s marginal cost (MC)?",
		"opts": {
			"q0": "A. Curve P",
			"q1": "B. Curve N",
			"q2": "C. Curve M",
			"q3": "D. Curve L",
			"q4": "E. "
		},
		"ans": "D",
		"sel": ""
	},
	"Q15": {
		"qs": "15.	The location of timber and plywood industries in West Africa is mainly influenced by the availability of",
		"opts": {
			"q0": "A. transport",
			"q1": "B. water",
			"q2": "C. raw materials",
			"q3": "D. labour supply",
			"q4": "E. "
		},
		"ans": "C",
		"sel": ""
	},
	"Q16": {
		"qs": "16.	The main objective of setting up private businesses is to",
		"opts": {
			"q0": "A. protect the interest of government",
			"q1": "B. maximize profits",
			"q2": "C. provide infrastructure",
			"q3": "D. promote exports",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
