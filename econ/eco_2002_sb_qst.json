		"qs": "17.	Small firms are important for the development of a country because",
		"opts": {
			"q0": "A. the prices of their products are usually high",
			"q1": "B. they render personalized services to the consumers",
			"q2": "C. they usually produce goods for the elite",
			"q3": "D. they do not normally provide after sales services",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
	},
	"Q18": {
		"qs": "18.	A limited liability company is owned by the",
