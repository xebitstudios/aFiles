		"opts": {
			"q0": "A. high death rate may lead to low productivity",
			"q1": "B. population may outgrow the means of subsistence",
			"q2": "C. people will always decide to have children",
			"q3": "D. migration may leave some parts of the world barren",
			"q4": "E. "
		},
		"ans": "B",
		"sel": ""
